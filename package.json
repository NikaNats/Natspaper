{
  "name": "natspaper",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "cross-env NODE_ENV=development astro dev",
    "build": "cross-env NODE_ENV=production astro check && astro build && npm run verify-build",
    "build:dev": "cross-env NODE_ENV=development astro check && astro build",
    "build:prod": "cross-env NODE_ENV=production astro check && astro build && npm run verify-build",
    "preview": "cross-env NODE_ENV=production astro preview",
    "verify-build": "node scripts/verify-build.js",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint . && stylelint \"src/styles/**/*.css\"",
    "lint:style": "stylelint \"src/styles/**/*.css\"",
    "lint:style:fix": "stylelint \"src/styles/**/*.css\" --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:workflows": "vitest run tests/workflows",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chrome": "playwright test --project=chromium",
    "test:all": "pnpm test:run && pnpm test:e2e",
    "security:audit": "pnpm audit --audit-level=high",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.3",
    "@expressive-code/plugin-collapsible-sections": "^0.41.7",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-georgian": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.1.2",
    "astro-expressive-code": "^0.41.7",
    "dayjs": "^1.11.20",
    "katex": "^0.16.44",
    "rehype-katex": "^7.0.1",
    "remark-collapse": "^0.1.2",
    "remark-math": "^6.0.0",
    "remark-toc": "^9.0.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@shikijs/transformers": "^4.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/ui": "^4.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sonda": "^0.11.1",
    "stylelint": "^17.6.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.astro": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0",
      "h3": ">=1.15.6",
      "svgo": ">=4.0.1",
      "fast-xml-parser": ">=5.5.6",
      "tar": ">=7.5.11",
      "minimatch": ">=10.2.3",
      "flatted": ">=3.4.2",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4"
    }
  }
}
